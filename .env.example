# ──────────────────────────────────────────────────────────────
# DealHunter AI — переменные окружения
# Скопируйте этот файл в .env и заполните реальными значениями.
# Никогда не коммитьте .env в репозиторий (см. .gitignore).
# ──────────────────────────────────────────────────────────────

# --- Общие ---
ENVIRONMENT=local          # local | staging | production
LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR
SECRET_KEY=change-me-to-a-random-secret-value

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000

# --- PostgreSQL ---
POSTGRES_USER=dealhunter
POSTGRES_PASSWORD=change-me
POSTGRES_DB=dealhunter
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://dealhunter:change-me@db:5432/dealhunter

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# --- Telegram Bot ---
BOT_TOKEN=your_bot_token_from_botfather
